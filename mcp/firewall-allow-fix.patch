         return await self.execute_active_response(data)
 
     async def firewall_allow(self, agent_id: str, src_ip: str) -> Dict[str, Any]:
-        """Remove firewall drop rule via active response."""
+        """Remove firewall drop rule via active response.
+
+        AI-CSL patch: upstream v4.2.1 omits the `alert.data.srcip` field,
+        which causes firewall-drop.sh on the agent to fail with
+        "Cannot read 'srcip' from data" and leave the iptables rule in place.
+        We mirror the `block_ip` structure so rollback actually works.
+        """
         self._validate_ip(src_ip)
         src_ip = self._sanitize_ar_argument(src_ip, "src_ip")
         data = {
             "command": "!firewall-drop",
             "agent_list": [agent_id],
             "arguments": [f"-srcip {src_ip}", "delete"],
+            "alert": {"data": {"srcip": src_ip}},
         }
         return await self.execute_active_response(data)
 
     async def host_allow(self, agent_id: str, src_ip: str) -> Dict[str, Any]:
-        """Remove hosts.deny entry via active response."""
+        """Remove hosts.deny entry via active response.
+
+        AI-CSL patch: same pattern as firewall_allow — include alert.data.srcip
+        so the agent-side script can find the IP it's supposed to unblock.
+        """
         self._validate_ip(src_ip)
         src_ip = self._sanitize_ar_argument(src_ip, "src_ip")
         data = {
             "command": "!host-deny",
             "agent_list": [agent_id],
             "arguments": [f"-srcip {src_ip}", "delete"],
+            "alert": {"data": {"srcip": src_ip}},
         }
         return await self.execute_active_response(data)
 
